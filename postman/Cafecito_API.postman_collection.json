{
  "info": {
    "name": "Cafecito API",
    "description": "Colección completa de endpoints para la API de Cafecito Feliz.\n\n## Configuración inicial\n1. Importar esta colección y el environment en Postman\n2. Seleccionar el environment \"Cafecito Local\"\n3. Ejecutar \"Login Admin\" para obtener el token automáticamente\n4. Seguir el orden sugerido: Auth → Productos → Clientes → Ventas → Tickets\n\n## Endpoints públicos\n- GET /products y GET /products/:id no requieren autenticación\n- POST /auth/register y POST /auth/login tampoco\n\n## Seed data disponible\n- Admin: admin@cafecito.com / admin123\n- Vendedor: vendedor@cafecito.com / vendedor123",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "productId",
      "value": ""
    },
    {
      "key": "customerId",
      "value": ""
    },
    {
      "key": "saleId",
      "value": ""
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "🏠 Health Check",
      "item": [
        {
          "name": "GET / — Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/",
              "host": ["{{baseUrl}}"],
              "path": [""]
            },
            "description": "Verifica que el servidor esté corriendo."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Responde con mensaje', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('message');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Nuevo Usuario\",\n  \"email\": \"nuevo@cafecito.com\",\n  \"password\": \"password123\",\n  \"role\": \"seller\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            },
            "description": "Registra un nuevo usuario. Retorna token y datos del usuario."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Retorna token y user', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('token');",
                  "    pm.expect(json.user).to.have.property('id');",
                  "    pm.expect(json.user).to.have.property('name');",
                  "    pm.expect(json.user).to.have.property('email');",
                  "    pm.expect(json.user).to.have.property('role');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login Admin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@cafecito.com\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Inicia sesión como admin. El token se guarda automáticamente en la variable {{token}}."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "",
                  "const json = pm.response.json();",
                  "pm.test('Retorna token', () => {",
                  "    pm.expect(json).to.have.property('token');",
                  "});",
                  "",
                  "if (json.token) {",
                  "    pm.collectionVariables.set('token', json.token);",
                  "    console.log('Token guardado:', json.token.slice(0, 20) + '...');",
                  "}",
                  "",
                  "pm.test('user.role es admin', () => {",
                  "    pm.expect(json.user.role).to.eql('admin');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login Vendedor",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
