    {
      "name": "💵 Ventas",
      "item": [
        {
          "name": "POST /sales — Crear venta (con cliente)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customer_id\": \"{{customerId}}\",\n  \"payment_method\": \"cash\",\n  \"items\": [\n    {\n      \"product_id\": \"{{productId}}\",\n      \"quantity\": 2\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/sales",
              "host": ["{{baseUrl}}"],
              "path": ["sales"]
            },
            "description": "Registra una venta aplicando descuento por fidelidad del cliente.\n\n- El descuento se calcula según purchasesCount del cliente (0→0%, 1-3→5%, 4-7→10%, 8+→15%)\n- Se reduce el stock de los productos\n- Se incrementa purchasesCount del cliente\n- Se genera el ticket automáticamente"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "",
                  "const json = pm.response.json();",
                  "pm.test('Venta creada con todos los campos', () => {",
                  "    pm.expect(json).to.have.property('id');",
                  "    pm.expect(json).to.have.property('customer_id');",
                  "    pm.expect(json).to.have.property('payment_method');",
                  "    pm.expect(json).to.have.property('items');",
                  "    pm.expect(json).to.have.property('subtotal');",
                  "    pm.expect(json).to.have.property('discount');",
                  "    pm.expect(json).to.have.property('total');",
                  "    pm.expect(json).to.have.property('ticket');",
                  "    pm.expect(json).to.have.property('created_at');",
                  "});",
                  "",
                  "pm.test('Items formateados', () => {",
                  "    pm.expect(json.items).to.be.an('array').with.lengthOf(1);",
                  "    const item = json.items[0];",
                  "    pm.expect(item).to.have.all.keys('product_id','product_name','quantity','unit_price','line_total');",
                  "});",
                  "",
                  "pm.test('Ticket generado', () => {",
                  "    const t = json.ticket;",
                  "    pm.expect(t).to.have.property('sale_id');",
                  "    pm.expect(t).to.have.property('store_name');",
                  "    pm.expect(t).to.have.property('items');",
                  "    pm.expect(t).to.have.property('discount');",
                  "    pm.expect(t.store_name).to.eql('Cafecito Feliz');",
                  "});",
                  "",
                  "pm.test('Subtotal coincide', () => {",
                  "    pm.expect(json.subtotal).to.eql(json.items[0].line_total);",
                  "});",
                  "",
                  "console.log('Venta ID:', json.id);",
                  "console.log('Total:', json.total);",
                  "console.log('Descuento:', json.discount.percentage * 100 + '%');",
                  "pm.collectionVariables.set('saleId', json.id);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
