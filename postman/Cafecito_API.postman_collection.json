              "path": ["auth", "me"]
            },
            "description": "Obtiene los datos del usuario autenticado."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Retorna user', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.user).to.have.property('id');",
                  "    pm.expect(json.user).to.have.property('name');",
                  "    pm.expect(json.user).to.have.property('email');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "☕ Productos",
      "item": [
        {
          "name": "GET /products — Listar (público)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products?page=1&limit=5",
              "host": ["{{baseUrl}}"],
              "path": ["products"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "5" }
              ]
            },
            "description": "Lista productos con paginación. No requiere token."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Respuesta paginada', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.all.keys('data','total','page','limit');",
                  "    pm.expect(json.data).to.be.an('array');",
                  "    pm.expect(json.page).to.eql(1);",
                  "    pm.expect(json.limit).to.eql(5);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "if (json.data && json.data.length > 0) {",
                  "    const p = json.data[0];",
                  "    pm.expect(p).to.have.all.keys('id','name','price','stock','created_at','updated_at');",
                  "    pm.collectionVariables.set('productId', p.id);",
                  "    console.log('ID producto guardado:', p.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
